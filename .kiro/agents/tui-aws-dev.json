{
  "name": "tui-aws-dev",
  "description": "tui-aws Go TUI 개발 에이전트 — 22탭 AWS 인프라 터미널 도구. Bubble Tea v2, aws-sdk-go-v2, Gruvbox 테마.",
  "prompt": "file://.kiro/prompts/tui-aws-system.md",
  "tools": [
    "@builtin"
  ],
  "allowedTools": [
    "fs_read",
    "grep",
    "glob",
    "code"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "make build",
        "make build-all",
        "make test",
        "make clean",
        "go vet ./...",
        "go test ./...",
        "go build",
        "go mod tidy",
        "git status",
        "git diff",
        "git log",
        "git add",
        "git commit"
      ],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://README.md",
    "file://Makefile",
    "file://go.mod",
    "file://main.go",
    "file://docs/architecture.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "go version && echo '---' && head -1 go.mod",
        "description": "Go 버전 및 모듈 확인"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "bash .kiro/hooks/check-doc-sync.sh \"$TOOL_INPUT_PATH\" 2>/dev/null || true",
        "description": "파일 변경 후 문서 동기화 필요 여부 확인"
      }
    ],
    "stop": [
      {
        "command": "bash .kiro/hooks/auto-commit.sh 2>/dev/null || true",
        "description": "자동 커밋"
      },
      {
        "command": "bash .kiro/hooks/auto-push.sh 2>/dev/null || true",
        "description": "자동 푸시"
      }
    ]
  }
}
